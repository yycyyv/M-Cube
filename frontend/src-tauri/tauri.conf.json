{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "M-Cube",
  "version": "0.1.1",
  "identifier": "com.yycyyv.mcube",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "M-Cube",
        "width": 1440,
        "height": 900,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "binaries": "binaries"
    },
    "icon": [
      "icons/icon.ico",
      "icons/icon.png",
      "icons/icon.icns"
    ]
  }
}

